# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb://localhost:27017/humans-first

# Optional: database name (defaults to "humans-first")
# MONGODB_DB_NAME=humans-first

# SMTP — seat reservation emails ("Join the movement" form)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM_NAME=Humans First
SMTP_FROM_EMAIL=noreply@example.com

# Inbox that receives new seat reservations (Join the movement form)
JOIN_NOTIFY_EMAIL=events@example.com

# Inbox that receives contact form messages (Contact Us form)
# Falls back to JOIN_NOTIFY_EMAIL when not set
CONTACT_NOTIFY_EMAIL=hello@example.com

# Public site URL — used for the logo in emails (must be publicly accessible)
SITE_URL=https://your-production-domain.com

# Optional: direct logo URL override for emails (use a transparent PNG for dark headers)
# EMAIL_LOGO_URL=https://your-production-domain.com/assets/figma/hero-mark.png
